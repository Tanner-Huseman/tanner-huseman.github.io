---
const links = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/tanner-huseman',
    description: 'Connect on LinkedIn',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/tanner-huseman',
    description: 'View GitHub profile',
  },
  {
    label: 'Email',
    href: 'mailto:tanner.huseman@gmail.com',
    description: 'Send an email',
  },
];
---

<footer id="connect" class="py-section px-6 md:px-16 border-t border-border">
  <div class="max-w-4xl mx-auto text-center">
    <p class="section-label mb-6">Get in touch</p>
    <h2 class="font-display text-text mb-4" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
      Let's build something.
    </h2>
    <p class="font-body text-muted text-lg mb-10 max-w-xl mx-auto leading-relaxed">
      I'm always happy to talk shop about data platforms, engineering challenges,
      or whatever you're building.
    </p>

    <!-- Primary CTA -->
    <a
      href="mailto:tanner.huseman@gmail.com"
      class="inline-flex items-center gap-2 px-10 py-4 rounded-full bg-accent text-white font-medium font-body text-lg hover:bg-accent/90 transition-all duration-200 hover:scale-105 mb-12"
    >
      Start a conversation
    </a>

    <!-- Social links -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      {links.map(({ label, href, description }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          aria-label={description}
          class="group flex items-center gap-3 px-8 py-4 rounded-full border border-border hover:border-accent/40 hover:bg-accent/5 transition-all duration-200"
        >
          <span class="font-body font-medium text-muted group-hover:text-text transition-colors">
            {label}
          </span>
          <span aria-hidden="true" class="text-muted group-hover:text-accent transition-colors">
            ↗
          </span>
        </a>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-24 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-muted">
        © {new Date().getFullYear()} Tanner Huseman
      </p>
      <p class="font-mono text-xs text-muted">
        Built with Astro · GSAP · Tailwind
      </p>
    </div>
  </div>
</footer>
