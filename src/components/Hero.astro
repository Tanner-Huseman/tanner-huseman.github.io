---
// Hero section — static Astro component, GSAP animates in client-side
---

<section
  id="hero"
  class="relative flex flex-col items-center justify-center min-h-screen px-6 text-center overflow-hidden"
  aria-label="Hero"
>
  <!-- Background gradient orb -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full opacity-20"
      style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
    ></div>
    <div
      class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full opacity-10"
      style="background: radial-gradient(circle, var(--color-highlight) 0%, transparent 70%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Eyebrow label -->
    <p
      id="hero-label"
      class="section-label mb-6 opacity-0"
      style="translate: none; rotate: none; scale: none; opacity: 0; transform: translateY(20px);"
    >
      Data Platform Engineer
    </p>

    <!-- Headline -->
    <h1
      id="hero-title"
      class="font-display text-hero text-text mb-6 leading-tight"
      style="opacity: 0; transform: translateY(40px);"
    >
      Tanner Huseman
    </h1>

    <!-- Tagline -->
    <p
      id="hero-tagline"
      class="font-body text-xl md:text-2xl text-muted max-w-2xl mx-auto mb-12 leading-relaxed"
      style="opacity: 0; transform: translateY(40px);"
    >
      From Broadway stages to data platforms.
    </p>

    <!-- CTAs -->
    <div
      id="hero-ctas"
      class="flex flex-col sm:flex-row items-center justify-center gap-4"
      style="opacity: 0; transform: translateY(40px);"
    >
      <a
        href="#story"
        class="px-8 py-3.5 rounded-full bg-accent text-white font-medium font-body hover:bg-accent/90 transition-all duration-200 hover:scale-105"
      >
        My story
      </a>
      <a
        href="#projects"
        class="px-8 py-3.5 rounded-full border border-border text-muted font-medium font-body hover:border-accent/40 hover:text-text transition-all duration-200"
      >
        See the work
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="hero-scroll"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0"
    aria-hidden="true"
  >
    <span class="font-mono text-xs text-muted tracking-widest">scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-muted to-transparent"></div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  if (!prefersReducedMotion) {
    const tl = gsap.timeline({ delay: 0.3 });

    tl.to('#hero-label', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
    })
      .to(
        '#hero-title',
        {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: 'power3.out',
        },
        '-=0.5'
      )
      .to(
        '#hero-tagline',
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out',
        },
        '-=0.6'
      )
      .to(
        '#hero-ctas',
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: 'power3.out',
        },
        '-=0.5'
      )
      .to(
        '#hero-scroll',
        {
          opacity: 1,
          duration: 0.6,
          ease: 'power2.out',
        },
        '-=0.2'
      );

    // Subtle parallax on the orbs
    gsap.to('.absolute.top-1\\/3', {
      y: -80,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
    });
  } else {
    // Show everything statically when reduced motion is preferred
    gsap.set(
      ['#hero-label', '#hero-title', '#hero-tagline', '#hero-ctas', '#hero-scroll'],
      { opacity: 1, y: 0 }
    );
  }
</script>
