---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: 'dbt Financial Data Platform',
    summary:
      'Production-grade dbt Core project modeling a realistic financial dataset. Staging → intermediate → mart architecture with SCD Type 2 snapshots, custom tests, and auto-generated docs.',
    tags: ['dbt Core', 'SQL', 'DuckDB', 'GitHub Actions', 'SCD Type 2'],
    href: '/projects/dbt-platform',
    gradient: 'linear-gradient(135deg, #FF694A, #f5a623)',
    status: 'in-progress' as const,
  },
  {
    title: 'AI Agent Toolkit',
    summary:
      'Composable Python library of AI agent skills built on the Claude API. DocGen, Code Review, and Content Writer agents with typed I/O, retry logic, and full test coverage.',
    tags: ['Python', 'Claude API', 'LangGraph', 'Pydantic', 'Pytest'],
    href: '/projects/ai-agents',
    gradient: 'linear-gradient(135deg, #6c5ce7, #4facfe)',
    status: 'in-progress' as const,
  },
  {
    title: 'Local Data Platform on Kubernetes',
    summary:
      'Fully containerized local data platform mirroring production: Kind cluster, ArgoCD GitOps, Airflow + dbt orchestration, LocalStack, Prometheus/Grafana monitoring.',
    tags: ['Kubernetes', 'ArgoCD', 'Helm', 'Airflow', 'Docker', 'LocalStack'],
    href: '/projects/k8s-platform',
    gradient: 'linear-gradient(135deg, #326CE5, #00d2a0)',
    status: 'in-progress' as const,
  },
  {
    title: 'Serverless Real Estate Data API',
    summary:
      'Production-style serverless API serving curated real estate data. FastAPI on Lambda, DynamoDB single-table design, Terraform IaC, auto-generated OpenAPI docs.',
    tags: ['FastAPI', 'AWS Lambda', 'DynamoDB', 'Terraform', 'Python'],
    href: '/projects/serverless-api',
    gradient: 'linear-gradient(135deg, #FF9900, #FF694A)',
    status: 'in-progress' as const,
  },
  {
    title: 'How I Built This Portfolio with AI',
    summary:
      'A 2,500-word technical article documenting the engineering process: why Astro + GSAP, the AI-assisted development workflow, and lessons learned.',
    tags: ['Technical Writing', 'Astro', 'MDX', 'GSAP', 'AI Workflow'],
    href: '/articles/how-i-built-this',
    gradient: 'linear-gradient(135deg, #f5a623, #6c5ce7)',
    status: 'in-progress' as const,
  },
  {
    title: 'This Portfolio Site',
    summary:
      'Open-sourced Astro static site with GSAP ScrollTrigger animations, 3D orbiting logos, Lighthouse 95+ performance, and GitHub Actions auto-deploy.',
    tags: ['Astro', 'React', 'GSAP', 'Tailwind', 'GitHub Pages'],
    href: 'https://github.com/tanner-huseman/tanner-huseman.github.io',
    gradient: 'linear-gradient(135deg, #00d2a0, #4facfe)',
    status: 'live' as const,
  },
];
---

<section id="projects" class="py-section px-6 md:px-16 max-w-7xl mx-auto">
  <!-- Section header -->
  <div class="mb-16">
    <p class="section-label mb-4">What I've built</p>
    <h2 class="font-display text-4xl md:text-5xl text-text max-w-xl">
      Projects
    </h2>
  </div>

  <!-- Single-column stack of wide cards -->
  <div
    id="projects-grid"
    class="flex flex-col gap-8"
  >
    {projects.map((project, i) => (
      <ProjectCard {...project} index={i} />
    ))}
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  if (!prefersReducedMotion) {
    gsap.fromTo(
      '#projects-grid .project-card',
      { opacity: 0, y: 50 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#projects-grid',
          start: 'top 85%',
          invalidateOnRefresh: true,
        },
      }
    );

    // Refresh positions after StoryTimeline pin spacers are inserted
    setTimeout(() => ScrollTrigger.refresh(), 500);
  }
</script>
