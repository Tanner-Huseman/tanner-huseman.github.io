---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StoryTimeline from '../components/StoryTimeline';
import SkillsGrid from '../components/SkillsGrid.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import ArticleList from '../components/ArticleList.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />

  <main id="main">

    <!-- ── 1. Hero ──────────────────────────────────────────────── -->
    <Hero />

    <!-- ── 2. Story ─────────────────────────────────────────────── -->
    <section id="story" class="py-section px-6 md:px-16 max-w-5xl mx-auto">
      <!-- Section header -->
      <div class="mb-12 md:mb-16">
        <p class="section-label mb-4">The journey</p>
        <h2 class="font-display text-4xl md:text-5xl text-text max-w-2xl">
          Three careers. One thread.
        </h2>
      </div>

      <StoryTimeline client:load />
    </section>

    <!-- ── 3. Skills ─────────────────────────────────────────────── -->
    <SkillsGrid />

    <!-- ── 4. Projects ───────────────────────────────────────────── -->
    <ProjectGrid />

    <!-- ── 5. Writing ────────────────────────────────────────────── -->
    <ArticleList />

    <!-- ── 6. Connect ────────────────────────────────────────────── -->
    <Footer />

  </main>
</BaseLayout>
